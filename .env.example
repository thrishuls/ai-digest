# Copy to .env for local testing. Never commit the real .env.
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Optional: header sent to OpenRouter (any URL works; just identifies the app).
OPENROUTER_REFERER=https://github.com/your-username/ai-digest

# Optional: change the brand name shown at the top of the page.
SITE_TITLE=AI Daily
